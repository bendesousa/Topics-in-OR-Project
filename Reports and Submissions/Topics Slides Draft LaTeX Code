%------------------------------------------------
\begin{frame}{Why Use Slack Variables?}
Instead of forcing every preference to hold exactly, we measure when it is violated. This makes the model more realistic and avoids unnecessary infeasibility.
\vspace{0.3cm}
\[
\sum_{i \in B_k} x_{i,t,d} \leq y_k
\qquad
\sum_{i \in I_k}(x_{i,4,d}+x_{i,5,d}) - 1 \leq b_d
\]

\begin{itemize}
    \item $y_k$ Measures optional-course overlap
    \item $b_d$ Measures lunch-break violations
\end{itemize}

\end{frame}

%------------------------------------------------
\begin{frame}{Objective Function}
\[
\min \sum_{k \in K} y_k + W\sum_{d \in D} b_d
\]

\vspace{0.3cm}
\begin{itemize}
    \item The solver is not searching for any feasible timetable.
    \item It is searching for the feasible timetable with the lowest total penalty.
\end{itemize}

\vspace{0.3cm}
\textbf{Interpretation:}
\begin{itemize}
    \item $\sum_{k\in K} y_k$: reduces overlap across programmes
    \item $\sum_{d\in D} b_d$: preserves lunch breaks where possible
    \item $W$: controls the priority placed on lunch protection
\end{itemize}

\end{frame}

