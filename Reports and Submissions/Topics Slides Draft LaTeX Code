\begin{frame}{Project Overview and Objectives}
\begin{itemize}
    \item \textbf{Goal:} Improve university timetabling using optimisation
    \item \textbf{Focus:} develop and validate a working model on Vet School data, then extend to the wider university dataset.
    \item \textbf{Approach:} formulate timetabling as a binary integer programming problem, with penalty variables for unavoidable timetable-quality violations.
\end{itemize}

