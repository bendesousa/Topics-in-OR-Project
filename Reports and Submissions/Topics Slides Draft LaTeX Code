%------------------------------------------------
\begin{frame}{Mathematical Structure of the Model}
\begin{itemize}
    \item We model timetabling as a binary optimisation problem.
    \item Main sets:
    \begin{itemize}
        \item $K$: Programme-year groups
        \item $I_k$: Courses in programme $k$
        \item $A_k \subseteq I_k$: Compulsory courses
        \item $B_k \subseteq I_k$: Optional courses
        \item $M$: Event types
        \item $T$: Teaching hours in the day
        \item $D$: Teaching days in the week
        \item $C$: Room capacities
    \end{itemize}
    \item This lets us model how whole degree programmes experience the timetable, not just individual classes.
\end{itemize}
\end{frame}

%------------------------------------------------
\begin{frame}{Parameters and Decision Variables}
\textbf{Key parameters:}
\begin{itemize}
    \item $d_{i,m}$: Weekly hours required for event type $m$ of course $i$
    \item $s_{i,m}$: No. of students attending event $m$ of course $i$
    \item $r_c$: No. of rooms with capacity $C$
    \item $P_k, P_k'$: Available and Required course choices in programme $k$
\end{itemize}

\vspace{0.3cm}
\[
x_{i,t,d} =
\begin{cases}
1 & \text{if event of course } i \text{ is scheduled at time } t \text{ on day } d \\
0 & \text{otherwise}
\end{cases}
\]

\vspace{0.2cm}
\textbf{Slack variables:}
\begin{itemize}
    \item $y_k$: Optional overlap penalty
    \item $b_d$: Lunch-break violation penalty on day $d$
\end{itemize}
\end{frame}

%------------------------------------------------
\begin{frame}{Decision Variable: Why it Matters}
\[
x_{i,m,t,d} =
\begin{cases}
1 & \text{if event } m \text{ of course } i \text{ is scheduled at time } t \text{ on day } d \\
0 & \text{otherwise}
\end{cases}
\]

\vspace{0.4cm}
\begin{itemize}
    \item This variable defines the timetable itself.
    \item All possible timetable correspond to a particular assignment of 0s and 1s.
    \item The solver searches through these assignments and keeps only those that satisfy the constraints.
\end{itemize}

\end{frame}

%------------------------------------------------
\begin{frame}{Core Constraints}
\textbf{Examples of Hard Constraints:}
\begin{itemize}
    \item No clashes between compulsory courses:
    \[
    \sum_{i \in A_k} x_{i,t,d} \leq 1
    \]
    \item Required teaching hours:
    \[
    \sum_{d \in D}\sum_{t \in T}\sum_{i \in A_k} x_{i,m,t,d} = d_{i,m}
    \]
    \item Room-capacity constraints
    \[
    \sum_{k \in K}\quad \sum_{i\in A_k, \quad m\in M: \quad s_{i,m} \leq c} s_{i,m} x_{i,t,d} \leq \sum_{c'\leq c}r_{c'}
    \]
\end{itemize}

These constraints capture student feasibility, delivery requirements and physical resource limits

\end{frame}

%------------------------------------------------
\begin{frame}{Hard Constraints vs Soft Constraints}
\textbf{Hard constraints} determine whether a timetable is feasible:
\begin{itemize}
    \item No compulsory clashes
    \item Correct weekly teaching hours
    \item Simultaneous events fit room capacity
\end{itemize}

\vspace{0.4cm}
\textbf{Soft constraints} determine timetable quality:
\begin{itemize}
    \item Lunch break between 12-2pm
    \item No teaching after 5pm
    \item Reduced Friday afternoon teaching
    \item Maximum daily teaching load
\end{itemize}

\end{frame}

%------------------------------------------------
\begin{frame}{Why These Constraints Make Sense}
\begin{itemize}
    \item \textbf{Compulsory clash constraint}
    \[
    \sum_{i \in A_k} x_{i,t,d} \leq 1
    \]
    ensures students can attend all required courses.

    \item \textbf{Optional vs compulsory constraint}
    prevents optional modules from becoming impossible choices.

    \item \textbf{Demand constraint}
    \[
    \sum_{d \in D}\sum_{t \in T} x_{i,m,t,d} = d_{i,m}
    \]
    ensures the correct number of hours is delivered.

    \item \textbf{Room-capacity constraints}
    ensure the timetable is physically implementable, not just mathematically feasible.
\end{itemize}
\end{frame}

%------------------------------------------------
\begin{frame}{Interpreting the Room-Capacity Constraint}
\[
\sum_{k \in K}\sum_{i \in I_k,\, m \in M:\, s_{i,m}\leq c} s_{i,m}x_{i,t,d}
\leq
\sum_{c' \leq c} r_{c'}
\]

\begin{itemize}
    \item This constraint checks whether all events running at the same time can be accommodated by the available room stock. 
\end{itemize}
